# Configuración para reportes.meridianltda.com
# Frontend Next.js estático + Backend API en el mismo servidor
# - /api/ -> backend/public/index.php
# - Archivos reales y /_next/ se sirven directamente
# - Fallback SPA -> index.html
# - HTML sin caché + evitar 206 (Range) en HTML
# - Assets con caché largo

RewriteEngine On

# --- API -> Backend PHP ---
RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ backend/public/index.php [L,QSA]

# --- Evitar listado de directorios y MultiViews ---
Options -Indexes -MultiViews
DirectoryIndex index.html

# --- No reescribir archivos/carpetas existentes (/_next/, imágenes, fonts, etc.) ---
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --- Fallback SPA: cualquier ruta que no sea un archivo real -> index.html ---
RewriteRule ^ index.html [L]

# --- Headers HTTP ---
<IfModule mod_headers.c>
  # HTML: sin caché (siempre sirve la versión más reciente)
  <FilesMatch "\.(html)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set Accept-Ranges "none"
  </FilesMatch>

  # Assets de Next.js (hash en el nombre): caché inmutable de 1 año
  <FilesMatch "\.(js|css|woff|woff2|png|jpg|jpeg|svg|gif|ico|webp|avif)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Seguridad básica
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
